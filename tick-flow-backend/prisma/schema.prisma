generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String? // null once Google-only sign-in exists
  createdAt    DateTime        @default(now())
  watchlist    WatchlistItem[]
  holdings     Holding[]
}

enum AssetType {
  stock
  etf
  crypto
}

// One row per buy lot — the same symbol can appear multiple times per user.
model Holding {
  id        String    @id @default(cuid())
  userId    String
  symbol    String
  qty       Float
  buyPrice  Float
  assetType AssetType @default(stock)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}
