# Copy to .env and fill in. Required vars are validated at boot (src/config/env.ts).
NODE_ENV=development
PORT=3000

# sim = SimulatedTickSource (dev/UAT), finnhub = real Finnhub WebSocket (prod, week 3)
TICK_SOURCE=sim

REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://tickflow:tickflow@localhost:5432/tickflow

# any long random string; signs the JWTs for REST + WS auth
JWT_SECRET=

# OAuth 2.0 Web client ID from Google Cloud Console (APIs & Services → Credentials).
# Optional: leave empty and /auth/google responds 503 "not configured".
GOOGLE_CLIENT_ID=

# Path to the Firebase service-account JSON (Project settings → Service accounts).
# Optional: leave empty and FCM pushes are logged to stdout instead of sent.
FIREBASE_SERVICE_ACCOUNT_PATH=

# https://finnhub.io/dashboard (free tier)
FINNHUB_API_KEY=

# https://site.financialmodelingprep.com/developer/docs (free tier, 250 calls/day) — used from week 5
FMP_API_KEY=
