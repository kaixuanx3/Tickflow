    "fastify": "^5.8.5",
    "firebase-admin": "^14.0.0",
    "google-auth-library": "^10.7.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.19.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
